{
  "name": "central-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"HUB,CLIMATE,MEME,DIARY,TRANSLATOR,DOMINO,PYTHON,PORTAL,GROCERY\" -c \"bgBlue.bold,bgGreen.bold,bgMagenta.bold,bgCyan.bold,bgYellow.bold,bgRed.bold,bgWhite.bold,bgBlack.bold,bgWhite\" \"npm run dev:hub\" \"npm run dev:climate\" \"npm run dev:meme\" \"npm run dev:diary\" \"npm run dev:translator\" \"npm run dev:domino\" \"npm run dev:python\" \"npm run dev:portal\" \"npm run dev:grocery\"",
    "dev:hub": "npx cross-env NEXT_TURBO=0 next dev -p 3000",
    "dev:climate": "cd ../climate-action-hub && npx cross-env NEXT_TURBO=0 next dev -p 3001",
    "dev:meme": "cd ../meme-generator-website && npx cross-env NEXT_TURBO=0 next dev -p 3002",
    "dev:diary": "cd ../my-digital-diary-app && npx cross-env NEXT_TURBO=0 next dev -p 3003",
    "dev:translator": "cd ../polyglot-translator && npx cross-env NEXT_TURBO=0 next dev -p 3004",
    "dev:domino": "cd ../domino-online-game && npx cross-env NEXT_TURBO=0 PRISMA_CLIENT_ENGINE_TYPE=binary next dev -p 3005",
    "dev:python": "cd \"../Python - Funzioni\" && npm run dev -- --port 3006",
    "dev:portal": "cd ../ClassPortalFullStack && npx cross-env NEXT_TURBO=0 next dev -p 3007",
    "dev:grocery": "cd ../grocery-app && npx expo start --web --port 3008",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
